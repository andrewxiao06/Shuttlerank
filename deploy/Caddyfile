# Caddy reverse proxy for the BRS API.
#
# Caddy automatically provisions and renews a Let's Encrypt TLS cert for
# API_DOMAIN (set in .env.prod). DNS for that name must already point at this
# EC2 box's public IP, and ports 80 + 443 must be open in the security group,
# before the cert can be issued.
#
# Until you own a domain: comment out the block below and use the :80 block at
# the bottom to test over plain HTTP against the EC2 public IP.

{$API_DOMAIN} {
	encode gzip
	reverse_proxy api:8000

	# Let Caddy answer ACME challenges + set sensible security headers.
	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options "nosniff"
		-Server
	}

	log {
		output stdout
		format console
	}
}

# ---------------------------------------------------------------------------
# No-domain fallback (HTTP only, no TLS). Uncomment to smoke-test before DNS
# is set up. Hit http://<ec2-public-ip>/health. Remove once the domain works.
# ---------------------------------------------------------------------------
# :80 {
# 	reverse_proxy api:8000
# }
