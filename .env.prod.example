# Production env for docker-compose.prod.yml. Copy to `.env.prod` on the EC2
# box and fill in real values. NEVER commit the filled-in .env.prod.
#
#   cp .env.prod.example .env.prod && nano .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Postgres (internal only; not exposed publicly) ------------------------
POSTGRES_USER=brs
POSTGRES_PASSWORD=CHANGE_ME_long_random_secret
POSTGRES_DB=brs

# --- Public hostname for the API (Caddy provisions TLS for this) -----------
# The DNS A record for this name must point at the EC2 public IP.
API_DOMAIN=api.yourdomain.com

# --- Clerk -----------------------------------------------------------------
# Your Clerk "Frontend API" URL. For the current dev instance this is:
#   https://organic-grizzly-1.clerk.accounts.dev
# When you create a production Clerk instance, swap this for its issuer.
CLERK_ISSUER=https://organic-grizzly-1.clerk.accounts.dev

# Restrict accepted tokens to your frontend origin(s). Comma-separated.
# Leave blank to skip the azp check.
CLERK_AUTHORIZED_PARTIES=https://yourdomain.com

# Webhook signing secret (Clerk dashboard -> Webhooks -> your endpoint).
CLERK_WEBHOOK_SECRET=whsec_CHANGE_ME

# Comma-separated Clerk user ids granted /admin endpoints.
BRS_ADMIN_USER_IDS=user_3E6zsJe01P0CQV1EDtaEmPIi0Dn

# --- CORS: which frontend origins may call the API -------------------------
# Your Vercel domain(s). Comma-separated, no trailing slash.
BRS_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Email notifications (Resend) ------------------------------------------
# When a match is submitted, the other players get an email to approve it.
# Leave RESEND_API_KEY blank to disable email entirely (in-app Inbox still
# works). Get a key at https://resend.com/api-keys (free tier is plenty).
RESEND_API_KEY=
# From header. Resend's onboarding@resend.dev works WITHOUT verifying a
# domain — good enough until you add your own domain in Resend.
EMAIL_FROM=ShuttleRank <onboarding@resend.dev>
# Public web URL used for the "Review" link in emails (your Vercel origin).
APP_URL=https://dubr-sepia.vercel.app

# --- Logging ---------------------------------------------------------------
SQL_ECHO=0

# CLERK_DEV_ALLOW_HEADER is intentionally absent. Setting it in production
# would let anyone impersonate any user via the X-Clerk-User-Id header.
