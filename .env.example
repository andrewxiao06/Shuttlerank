# Copy to .env and adjust for local non-docker runs.
# docker compose reads the inline `environment:` block in compose.yml,
# so this file is only consumed when running uvicorn directly.

# Postgres — asyncpg driver
DATABASE_URL=postgresql+asyncpg://brs:brs@localhost:5432/brs

# Redis (used by the leaderboard sorted-set cache, not the API itself yet)
REDIS_URL=redis://localhost:6379/0

# Set to 1 to echo every SQL statement to stdout. Off by default.
SQL_ECHO=0

# ---------------------------------------------------------------------------
# Clerk auth
# ---------------------------------------------------------------------------
# Issuer of Clerk session JWTs. Dev: https://<app>.clerk.accounts.dev
# Prod:   https://clerk.yourdomain.com  (your Clerk "Frontend API" URL)
# Required for Bearer-token verification; JWKS is fetched from
# {CLERK_ISSUER}/.well-known/jwks.json unless CLERK_JWKS_URL overrides it.
CLERK_ISSUER=
# CLERK_JWKS_URL=

# Optional CSV of allowed `azp` (authorized party) origins. When set, tokens
# whose azp is not listed are rejected. Leave blank to skip the check.
# CLERK_AUTHORIZED_PARTIES=https://yourdomain.com,https://www.yourdomain.com

# Webhook signing secret (Clerk dashboard → Webhooks). Required in prod.
CLERK_WEBHOOK_SECRET=

# Comma-separated Clerk user ids granted admin endpoints.
BRS_ADMIN_USER_IDS=

# DEV/TEST ONLY — trust the unverified `X-Clerk-User-Id` header instead of a
# real JWT. NEVER set this in production; it is a full impersonation bypass.
# CLERK_DEV_ALLOW_HEADER=1
